# Azure DevOps Configuration
AZURE_DEVOPS_PAT=your-pat-here
AZURE_DEVOPS_ORG=continia-software
AZURE_DEVOPS_PROJECT=Continia Software
AZURE_DEVOPS_REPO_IDS=your-repo-id-here

# To find repo IDs, run:
#   curl -u ":YOUR_PAT" "https://dev.azure.com/continia-software/Continia%20Software/_apis/git/repositories?api-version=7.0"

# Optional: Custom field name for release notes (default: Custom.ReleaseNotes)
# RELEASE_NOTES_FIELD=Custom.ReleaseNotes

# Optional: Polling interval in minutes (default: 15)
# POLL_INTERVAL_MINUTES=15

# Optional: Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: Path to release note prompt file (default: .claude/commands/do-CreateReleaseNoteContinia.md)
# RELEASE_NOTE_PROMPT_PATH=.claude/commands/do-CreateReleaseNoteContinia.md

# Optional: State file directory (default: .state)
# STATE_DIR=.state
